# DavidAI environment variables
# Copy to .env and replace placeholders. Do not commit .env to git.

# Flask session secret — use a long random string
DAVIDAI_SECRET_KEY=<CHANGE_ME_TO_A_STRONG_SECRET>

# PostgreSQL connection (davidai_dev)
DAVIDAI_DATABASE_URL=postgresql+psycopg2://postgres:<YOUR_POSTGRES_PASSWORD>@localhost:5432/davidai_dev

# Twilio SMS (optional — SOS alerts to primary trusted contact)
# Copy values into .env only. Never commit .env.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_ENABLED=false
